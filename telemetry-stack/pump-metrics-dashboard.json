      "panel-1": {
        "kind": "Panel",
        "spec": {
          "id": 1,
          "title": "Hydraulic Pump Temperatures (Celsius)",
          "description": "",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "influxdb",
                      "version": "v0",
                      "datasource": {
                        "name": "bfpey8c9xa8sga"
                      },
                      "spec": {
                        "query": "from(bucket: \"telemetry_data\")\r\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\r\n  |> filter(fn: (r) => r._measurement == \"factory_pumps_final\")\r\n  |> filter(fn: (r) => r._field == \"metrics_temperature_c\")\r\n  // Map function to translate the IDs:\r\n  |> map(fn: (r) => ({\r\n      r with _field:\r\n        if r.device_id == \"mqttx_1b8a0257_1\" then \"Main Cooling Pump\"\r\n        else if r.device_id == \"mqttx_1b8a0257_2\" then \"Oil Return Pump\"\r\n        else if r.device_id == \"mqttx_1b8a0257_3\" then \"Auxiliary Pump A\"\r\n        else if r.device_id == \"mqttx_1b8a0257_4\" then \"Auxiliary Pump B\"\r\n        else if r.device_id == \"mqttx_1b8a0257_5\" then \"Chiller Feed Pump\"\r\n        else r.device_id\r\n    }))\r\n  |> aggregateWindow(every: 10s, fn: last, createEmpty: true)\r\n  |> fill(usePrevious: true)\r\n  |> yield(name: \"last\")"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {
                "interval": "10s"
              }
            }
          },
